# ╔════════════════════════════════════════════════════════════════╗
# ║  OS Education Center — Environment Configuration              ║
# ║  Copy this file to .env and fill in your values.              ║
# ║  NEVER commit .env to version control.                        ║
# ╚════════════════════════════════════════════════════════════════╝

# ── Flask core ──────────────────────────────────────────────────────────────
FLASK_ENV=production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<CHANGE-ME-random-64-char-hex>

# ── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
# Connection pool (tune for your plan — MongoDB Atlas free tier: max 500 connections)
MONGO_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SERVER_SELECT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=10000

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ⚠ Rotate this key on every new deployment.
JWT_SECRET_KEY=<CHANGE-ME-random-64-char-hex>
JWT_ACCESS_TOKEN_EXPIRES_HOURS=8

# ── Admin seed account ───────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<CHANGE-ME-strong-password>
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@oseducationcenter.com

# ── Cloudinary (file storage) ─────────────────────────────────────────────────
# Sign up at cloudinary.com — free tier is sufficient for most installs
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ── Groq (AI grading of written answers) ─────────────────────────────────────
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama-3.3-70b-versatile

# ── Email (Flask-Mail via Gmail SMTP) ─────────────────────────────────────────
# Create a Gmail App Password at: https://myaccount.google.com/apppasswords
# Leave MAIL_USERNAME empty to disable email (notifications will be suppressed).
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=<your-gmail-address>
MAIL_PASSWORD=<your-gmail-app-password>
MAIL_DEFAULT_SENDER=noreply@oseducationcenter.com

# ── Sentry (error monitoring) ──────────────────────────────────────────────────
# Sign up at sentry.io (free tier available). Leave empty to disable.
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>

# ── Rate limiting ──────────────────────────────────────────────────────────────
# Default: in-memory (resets on restart, doesn't work across multiple workers).
# For production with Gunicorn multi-worker: use Redis.
#   docker run -d -p 6379:6379 redis
#   RATELIMIT_STORAGE_URI=redis://localhost:6379/0
#   (also: pip install redis, or uncomment it in requirements.txt)
RATELIMIT_STORAGE_URI=memory://
LOGIN_RATE_LIMIT=5 per minute;20 per hour
PASSWORD_RESET_RATE_LIMIT=3 per minute;10 per hour

# ── Security headers (flask-talisman) ──────────────────────────────────────────
# Leave false if a reverse proxy (nginx/Caddy/your platform's load balancer)
# already terminates TLS and forwards plain HTTP to this app — that's the
# normal setup and the proxy should redirect HTTP->HTTPS, not Flask. Only set
# true if Flask itself is the TLS endpoint (no proxy in front of it).
TALISMAN_FORCE_HTTPS=false

# ── Logging ─────────────────────────────────────────────────────────────────────
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT: "json" (recommended in production, one JSON object per line —
#   easy to ship to CloudWatch/Loki/Datadog and filter by request_id) or
#   "text" (human-readable, default in dev). ProductionConfig defaults to json.
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── File upload limits ─────────────────────────────────────────────────────────
# MAX_CONTENT_LENGTH_MB: Flask-level hard cap (applies to ALL request bodies)
MAX_CONTENT_LENGTH_MB=50

# ── Password reset ─────────────────────────────────────────────────────────────
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=30

# ── Center info (printed on certificates) ─────────────────────────────────────
CENTER_NAME=OS Education Center
CENTER_ADDRESS=Assam, India
CENTER_WEBSITE=https://oseducationcenter.com
CENTER_PHONE=+91-XXXXXXXXXX

# ── Deployment ────────────────────────────────────────────────────────────────
# Used by /health/ready to report the current build version
APP_VERSION=1.0.0
